# ── LLM Provider ───────────────────────────────────────────────────────────
# Choose your LLM backend: anthropic (default), openai, or gemini
DEVBOTS_PROVIDER=anthropic

# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_api_key_here

# ── OpenAI-compatible (used when DEVBOTS_PROVIDER=openai) ──────────────────
# Works with OpenAI, Groq, Mistral, Ollama, and any OpenAI-compatible API.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1   # omit for default OpenAI endpoint

# ── Google Gemini (used when DEVBOTS_PROVIDER=gemini) ──────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIza...

# ── Model overrides (optional) ─────────────────────────────────────────────
# Defaults to Claude Haiku. If you switch providers, replace this with a
# model that exists on that provider before running `uv run chat`.
DEVBOTS_MODEL=claude-haiku-4-5-20251001
# GITBOT_MODEL=claude-sonnet-4-6
# QABOT_MODEL=claude-haiku-4-5-20251001
# ISSUEBOT_MODEL=claude-haiku-4-5-20251001
# ORCHESTRATOR_MODEL=claude-haiku-4-5-20251001
# JOURNALBOT_MODEL=claude-haiku-4-5-20251001
# TASKBOT_MODEL=claude-haiku-4-5-20251001
# HABITBOT_MODEL=claude-haiku-4-5-20251001
# NOTEBOT_MODEL=claude-haiku-4-5-20251001

# ── Git defaults ───────────────────────────────────────────────────────────
DEVBOTS_MAX_COMMITS=100
DEVBOTS_DEFAULT_BRANCH=HEAD

# ── GitLab ─────────────────────────────────────────────────────────────────
# Create a Personal Access Token at:
#   https://gitlab.com/-/profile/personal_access_tokens
# Required scopes: read_api
GITLAB_TOKEN=your_gitlab_token_here

# ── GitHub ─────────────────────────────────────────────────────────────────
# Create a Personal Access Token at:
#   https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public only)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# ── PageSpeed (optional — used by `uv run pagespeedbot`) ───────────────────
PAGESPEED_API_KEY=             # Google PageSpeed Insights API key

# ── Slack Integration (optional — run `uv run slackbot`) ───────────────────
# See docs/slack-integration.md for setup instructions.
SLACK_BOT_TOKEN=              # xoxb-... Bot OAuth token
SLACK_APP_TOKEN=              # xapp-... App-level token (Socket Mode)
SLACKBOT_LOG_LEVEL=INFO       # Optional: DEBUG, INFO, WARNING, ERROR
